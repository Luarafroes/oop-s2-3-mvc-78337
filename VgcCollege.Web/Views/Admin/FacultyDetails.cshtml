@model VgcCollege.Domain.Entities.FacultyProfile
@{
    ViewData["Title"] = $"Faculty Details - {Model.Name}";
    var assignedCourses = ViewBag.AssignedCourses as List<VgcCollege.Domain.Entities.Course>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 fw-bold mb-1">@Model.Name</h1>
        <p class="text-muted">Faculty Member</p>
    </div>
    <div>
        <a asp-action="EditFaculty" asp-route-id="@Model.Id" class="btn btn-warning me-2">
            <i class="bi bi-pencil me-2"></i>Edit
        </a>
        <a asp-action="Faculty" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Contact Information -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Contact Information</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>
                </dl>
            </div>
        </div>

        <!-- Teaching Summary -->
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-info text-white py-3">
                <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Teaching Summary</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6">
                        <h3 class="mb-0 text-primary">@(assignedCourses?.Count ?? 0)</h3>
                        <small class="text-muted">Assigned Courses</small>
                    </div>
                    <div class="col-6">
                        @{
                            var totalStudents = assignedCourses?.Sum(c => c.Enrolments?.Count ?? 0) ?? 0;
                        }
                        <h3 class="mb-0 text-success">@totalStudents</h3>
                        <small class="text-muted">Total Students</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Assigned Courses -->
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0"><i class="bi bi-journal-bookmark-fill me-2"></i>Assigned Courses</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course Name</th>
                            <th>Branch</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Students</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (assignedCourses?.Any() == true)
                        {
                            @foreach (var course in assignedCourses)
                            {
                                <tr>
                                    <td class="fw-semibold">@course.Name</td>
                                    <td>@course.Branch?.Name</td>
                                    <td>@course.StartDate.ToString("dd MMM yyyy")</td>
                                    <td>@course.EndDate.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge bg-secondary">@(course.Enrolments?.Count ?? 0)</span></td>
                                    <td>
                                        <a asp-action="CourseDetails" asp-route-id="@course.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            View <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-info-circle me-1"></i> No courses assigned to this faculty member.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
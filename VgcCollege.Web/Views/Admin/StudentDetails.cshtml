@model VgcCollege.Domain.Entities.StudentProfile
@{
    ViewData["Title"] = $"Student Details - {Model.Name}";
    var enrolments = ViewBag.Enrolments as List<VgcCollege.Domain.Entities.CourseEnrolment>;
    var assignmentResults = ViewBag.AssignmentResults as List<VgcCollege.Domain.Entities.AssignmentResult>;
    var examResults = ViewBag.ExamResults as List<VgcCollege.Domain.Entities.ExamResult>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 fw-bold mb-1">@Model.Name</h1>
        <p class="text-muted">Student ID: @Model.StudentNumber</p>
    </div>
    <div>
        <a asp-action="EditStudent" asp-route-id="@Model.Id" class="btn btn-warning me-2">
            <i class="bi bi-pencil me-2"></i>Edit
        </a>
        <a asp-action="Students" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Personal Information -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>Personal Information</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Student Number</dt>
                    <dd class="col-sm-7"><span class="badge bg-secondary">@Model.StudentNumber</span></dd>

                    <dt class="col-sm-5">Email</dt>
                    <dd class="col-sm-7">@Model.Email</dd>

                    <dt class="col-sm-5">Phone</dt>
                    <dd class="col-sm-7">@Model.Phone</dd>

                    <dt class="col-sm-5">Date of Birth</dt>
                    <dd class="col-sm-7">@Model.DateOfBirth.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-5">Address</dt>
                    <dd class="col-sm-7">@Model.Address</dd>
                </dl>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-info text-white py-3">
                <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Academic Summary</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6 mb-3">
                        <h3 class="mb-0 text-primary">@(enrolments?.Count ?? 0)</h3>
                        <small class="text-muted">Enrolled Courses</small>
                    </div>
                    <div class="col-6 mb-3">
                        <h3 class="mb-0 text-success">@(assignmentResults?.Count ?? 0)</h3>
                        <small class="text-muted">Assignments</small>
                    </div>
                    <div class="col-6">
                        <h3 class="mb-0 text-warning">@(examResults?.Count ?? 0)</h3>
                        <small class="text-muted">Exams Taken</small>
                    </div>
                    <div class="col-6">
                        @{
                            var avgScore = assignmentResults?.Any() == true
                            ? assignmentResults.Average(r => r.Score).ToString("F0")
                            : "0";
                        }
                        <h3 class="mb-0 text-danger">@avgScore%</h3>
                        <small class="text-muted">Average Grade</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Enrolled Courses -->
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0"><i class="bi bi-journal-bookmark-fill me-2"></i>Enrolled Courses</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course Name</th>
                            <th>Branch</th>
                            <th>Enrolled Date</th>
                            <th>Status</th>
                            <th>Attendance</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (enrolments?.Any() == true)
                        {
                            @foreach (var enrolment in enrolments)
                            {
                                var attendancePercent = enrolment.AttendanceRecords?.Any() == true
                                ? (enrolment.AttendanceRecords.Count(a => a.Present) * 100 / enrolment.AttendanceRecords.Count)
                                : 0;
                                <tr>
                                    <td class="fw-semibold">@enrolment.Course?.Name</td>
                                    <td>@enrolment.Course?.Branch?.Name</td>
                                    <td>@enrolment.EnrolDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <span class="badge @(enrolment.Status == "Active" ? "bg-success" : "bg-secondary")">
                                            @enrolment.Status
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress" style="width: 80px; height: 6px;">
                                                <div class="progress-bar @(attendancePercent >= 75 ? "bg-success" : attendancePercent >= 50 ? "bg-warning" : "bg-danger")"
                                                     style="width: @attendancePercent%"></div>
                                            </div>
                                            <small>@attendancePercent%</small>
                                        </div>
                                    </td>
                                    <td>
                                        <a asp-action="CourseDetails" asp-route-id="@enrolment.CourseId"
                                           class="btn btn-sm btn-outline-primary">
                                            View Course <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-info-circle me-1"></i> Not enrolled in any courses.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Assignment Results -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white py-3">
                <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Assignment Results</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th>Assignment</th>
                            <th>Score</th>
                            <th>Feedback</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (assignmentResults?.Any() == true)
                        {
                            @foreach (var result in assignmentResults)
                            {
                                <tr>
                                    <td>@result.Assignment?.Course?.Name</td>
                                    <td class="fw-semibold">@result.Assignment?.Title</td>
                                    <td>
                                        <span class="badge @(result.Score >= 70 ? "bg-success" : result.Score >= 50 ? "bg-warning" : "bg-danger")">
                                            @result.Score / @result.Assignment?.MaxScore
                                        </span>
                                    </td>
                                    <td>@result.Feedback</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    <i class="bi bi-info-circle me-1"></i> No assignment results recorded.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Exam Results -->
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark py-3">
                <h5 class="mb-0"><i class="bi bi-trophy me-2"></i>Exam Results</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th>Exam</th>
                            <th>Score</th>
                            <th>Grade</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (examResults?.Any() == true)
                        {
                            @foreach (var result in examResults)
                            {
                                <tr>
                                    <td>@result.Exam?.Course?.Name</td>
                                    <td class="fw-semibold">@result.Exam?.Title</td>
                                    <td>@result.Score / @result.Exam?.MaxScore</td>
                                    <td><span class="badge bg-info">@result.Grade</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    <i class="bi bi-info-circle me-1"></i> No exam results recorded.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
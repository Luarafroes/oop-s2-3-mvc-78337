@model List<VgcCollege.Domain.Entities.StudentProfile>
@{
    ViewData["Title"] = "Manage Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Students</h1>
        <p class="text-muted">Manage student records</p>
    </div>
    <a asp-action="CreateStudent" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Add Student
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Student Number</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@student.StudentNumber</span></td>
                        <td class="fw-semibold">@student.Name</td>
                        <td>@student.Email</td>
                        <td>@student.Phone</td>
                        <td>
                            <a asp-action="EditStudent" asp-route-id="@student.Id" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="DeleteStudent" asp-route-id="@student.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
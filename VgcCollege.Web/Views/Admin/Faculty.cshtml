@model List<VgcCollege.Domain.Entities.FacultyProfile>
@{
    ViewData["Title"] = "Manage Faculty";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Faculty</h1>
        <p class="text-muted">Manage teaching staff</p>
    </div>
    <a asp-action="CreateFaculty" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Add Faculty
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Courses</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var faculty in Model)
                {
                    <tr>
                        <td class="fw-semibold">@faculty.Name</td>
                        <td>@faculty.Email</td>
                        <td>@faculty.Phone</td>
                        <td>
                            @foreach (var assignment in faculty.CourseAssignments?.Take(2) ?? new List<VgcCollege.Domain.Entities.FacultyCourseAssignment>())
                            {
                                <span class="badge bg-secondary me-1">@assignment.Course?.Name</span>
                            }
                            @if ((faculty.CourseAssignments?.Count ?? 0) > 2)
                            {
                                <span class="badge bg-info">+@(faculty.CourseAssignments.Count - 2)</span>
                            }
                        </td>
                        <td>
                            <a asp-action="EditFaculty" asp-route-id="@faculty.Id" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="DeleteFaculty" asp-route-id="@faculty.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
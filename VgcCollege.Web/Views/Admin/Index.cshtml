@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header">
    <h1 class="display-5 fw-bold mb-2">Admin Dashboard</h1>
    <p class="text-muted">Welcome back! Here's what's happening at VGC College today.</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card stat-card bg-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-1">Total Branches</h6>
                        <h2 class="display-6 fw-bold mb-0">@ViewBag.BranchCount</h2>
                    </div>
                    <i class="bi bi-buildings fs-1 text-white-50"></i>
                </div>
                <a asp-action="Branches" class="btn btn-light btn-sm mt-3 w-100">Manage Branches →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-1">Active Courses</h6>
                        <h2 class="display-6 fw-bold mb-0">@ViewBag.CourseCount</h2>
                    </div>
                    <i class="bi bi-book fs-1 text-white-50"></i>
                </div>
                <a asp-action="Courses" class="btn btn-light btn-sm mt-3 w-100">Manage Courses →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-info text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-1">Enrolled Students</h6>
                        <h2 class="display-6 fw-bold mb-0">@ViewBag.StudentCount</h2>
                    </div>
                    <i class="bi bi-people fs-1 text-white-50"></i>
                </div>
                <a asp-action="Students" class="btn btn-light btn-sm mt-3 w-100">Manage Students →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-warning text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-1">Faculty Members</h6>
                        <h2 class="display-6 fw-bold mb-0">@ViewBag.FacultyCount</h2>
                    </div>
                    <i class="bi bi-person-badge fs-1 text-white-50"></i>
                </div>
                <a asp-action="Faculty" class="btn btn-light btn-sm mt-3 w-100">Manage Faculty →</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-calendar-week me-2"></i>Recent Activity</h5>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <div class="list-group-item border-0 px-0">
                        <div class="d-flex">
                            <div class="flex-shrink-0">
                                <i class="bi bi-plus-circle text-success fs-5"></i>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <p class="mb-0">New courses added this semester</p>
                                <small class="text-muted">System is ready for new registrations</small>
                            </div>
                        </div>
                    </div>
                    <div class="list-group-item border-0 px-0">
                        <div class="d-flex">
                            <div class="flex-shrink-0">
                                <i class="bi bi-trophy text-warning fs-5"></i>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <p class="mb-0">Exam results pending release</p>
                                <small class="text-muted">Review and release exam results for students</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-question-circle me-2"></i>Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-action="Branches" class="btn btn-outline-primary">
                        <i class="bi bi-buildings me-2"></i>Manage Branches
                    </a>
                    <a asp-action="Courses" class="btn btn-outline-success">
                        <i class="bi bi-book me-2"></i>Manage Courses
                    </a>
                    <a asp-action="Students" class="btn btn-outline-info">
                        <i class="bi bi-people me-2"></i>Manage Students
                    </a>
                    <a asp-action="Faculty" class="btn btn-outline-warning">
                        <i class="bi bi-person-badge me-2"></i>Manage Faculty
                    </a>
                    <a asp-action="ExamResults" class="btn btn-outline-danger">
                        <i class="bi bi-trophy me-2"></i>Release Exam Results
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
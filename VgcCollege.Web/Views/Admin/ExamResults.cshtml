@model List<VgcCollege.Domain.Entities.Exam>
@{
    ViewData["Title"] = "Exam Results";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Exam Results</h1>
        <p class="text-muted">Control when students can see their exam results</p>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Course</th>
                    <th>Exam Title</th>
                    <th>Date</th>
                    <th>Max Score</th>
                    <th>Results Released</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exam in Model)
                {
                    <tr>
                        <td>@exam.Course?.Name</td>
                        <td class="fw-semibold">@exam.Title</td>
                        <td>@exam.Date.ToShortDateString()</td>
                        <td>@exam.MaxScore</td>
                        <td>
                            @if (exam.ResultsReleased)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle me-1"></i> Released
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-lock me-1"></i> Hidden
                                </span>
                            }
                        </td>
                        <td>
                            <form asp-action="ToggleExamRelease" method="post">
                                <input type="hidden" name="examId" value="@exam.Id" />
                                @Html.AntiForgeryToken()
                                @if (exam.ResultsReleased)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-eye-slash me-1"></i> Hide from Students
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-eye me-1"></i> Release to Students
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
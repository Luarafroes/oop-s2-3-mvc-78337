@model List<VgcCollege.Domain.Entities.Course>
@{
    ViewData["Title"] = "Manage Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Courses</h1>
        <p class="text-muted">Manage academic courses</p>
    </div>
    <a asp-action="CreateCourse" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Add Course
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Branch</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Students</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td class="fw-semibold">@course.Name</td>
                        <td>@course.Branch?.Name</td>
                        <td>@course.StartDate.ToShortDateString()</td>
                        <td>@course.EndDate.ToShortDateString()</td>
                        <td><span class="badge bg-secondary">@course.Enrolments?.Count</span></td>
                        <td>
                            <a asp-action="EditCourse" asp-route-id="@course.Id" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="DeleteCourse" asp-route-id="@course.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
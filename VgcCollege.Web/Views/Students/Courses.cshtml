@model List<VgcCollege.Domain.Entities.CourseEnrolment>
@{
    ViewData["Title"] = "My Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">My Courses</h1>
        <p class="text-muted">Your enrolled courses</p>
    </div>
</div>

<div class="row g-4">
    @foreach (var enrolment in Model)
    {
        var attendancePercent = enrolment.AttendanceRecords?.Any() == true
            ? (enrolment.AttendanceRecords.Count(a => a.Present) * 100 / enrolment.AttendanceRecords.Count)
            : 0;
        
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">@enrolment.Course?.Name</h5>
                </div>
                <div class="card-body">
                    <p><i class="bi bi-buildings me-2"></i>Branch: @enrolment.Course?.Branch?.Name</p>
                    <p><i class="bi bi-calendar me-2"></i>@enrolment.Course?.StartDate.ToShortDateString() - @enrolment.Course?.EndDate.ToShortDateString()</p>
                    <p><i class="bi bi-check-circle me-2"></i>Status: <span class="badge bg-success">@enrolment.Status</span></p>
                    
                    <div class="mt-3">
                        <label class="form-label">Attendance: @attendancePercent%</label>
                        <div class="progress">
                            <div class="progress-bar @(attendancePercent >= 75 ? "bg-success" : attendancePercent >= 50 ? "bg-warning" : "bg-danger")" 
                                 style="width: @attendancePercent%">
                                @attendancePercent%
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <a asp-controller="Students" asp-action="Results" class="btn btn-sm btn-outline-primary">
                        View Results <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>
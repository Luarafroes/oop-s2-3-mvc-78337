@{
    ViewData["Title"] = "Faculty Dashboard";
    var faculty = ViewBag.Faculty as VgcCollege.Domain.Entities.FacultyProfile;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Welcome, @faculty?.Name!</h1>
        <p class="text-muted">Faculty Dashboard — @DateTime.Now.ToString("MMMM dd, yyyy")</p>
    </div>
    <div class="text-muted small">
        <i class="bi bi-envelope me-1"></i> @faculty?.Email
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-journal-bookmark-fill text-primary fs-3"></i>
                </div>
                <div>
                    <p class="text-muted mb-0 small">My Courses</p>
                    <h2 class="mb-0 fw-bold">@ViewBag.TotalCourses</h2>
                </div>
            </div>
            <div class="card-footer bg-white border-0 pt-0">
                <a asp-action="MyStudents" class="btn btn-sm btn-outline-primary w-100">
                    View Students <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-people text-success fs-3"></i>
                </div>
                <div>
                    <p class="text-muted mb-0 small">My Students</p>
                    <h2 class="mb-0 fw-bold">@ViewBag.TotalStudents</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-clock-history text-warning fs-3"></i>
                </div>
                <div>
                    <p class="text-muted mb-0 small">Pending Grading</p>
                    <h2 class="mb-0 fw-bold text-warning">@ViewBag.PendingGrading</h2>
                </div>
            </div>
            <div class="card-footer bg-white border-0 pt-0">
                <a asp-action="Assignments" class="btn btn-sm btn-outline-warning w-100">
                    Grade Now <i class="bi bi-pencil-square"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header table-dark text-white">
        <h5 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Quick Actions</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <a asp-action="MyStudents" class="btn btn-outline-primary w-100 py-3">
                    <i class="bi bi-people fs-4 d-block mb-2"></i>
                    View My Students
                </a>
            </div>
            <div class="col-md-4">
                <a asp-action="Assignments" class="btn btn-outline-warning w-100 py-3">
                    <i class="bi bi-pencil-square fs-4 d-block mb-2"></i>
                    Enter Grades
                </a>
            </div>
        </div>
    </div>
</div>
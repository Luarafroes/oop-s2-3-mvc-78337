@model List<VgcCollege.Domain.Entities.Assignment>
@{
    ViewData["Title"] = "Assignments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Assignments</h1>
        <p class="text-muted">Manage and grade student assignments</p>
    </div>
</div>

<div class="row g-4">
    @if (Model.Any())
    {
        @foreach (var assignment in Model)
        {
            var isOverdue = assignment.DueDate < DateTime.Today;
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header @(isOverdue ? "bg-danger text-white" : "bg-secondary text-white")">
                        <h5 class="mb-0">@assignment.Title</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-2">Course: <strong>@assignment.Course?.Name</strong></p>
                        <p class="mb-2">Due Date: @assignment.DueDate.ToShortDateString()</p>
                        <p>Max Score: <strong>@assignment.MaxScore</strong></p>
                        @if (isOverdue)
                        {
                            <div class="alert alert-warning py-1 mb-2">
                                <i class="bi bi-exclamation-triangle me-1"></i> Overdue
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-white">
                        <a asp-action="EnterGrades" asp-route-courseId="@assignment.CourseId" 
                           class="btn btn-primary w-100">
                            <i class="bi bi-pencil-square me-1"></i> Enter Grades
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info text-center">
                <i class="bi bi-info-circle me-2"></i> No assignments found for your courses.
            </div>
        </div>
    }
</div>
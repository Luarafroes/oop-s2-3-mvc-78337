@model List<VgcCollege.Domain.Entities.StudentProfile>
@{
    ViewData["Title"] = "My Students";
    var studentCourses = ViewBag.StudentCourses as Dictionary<int, List<VgcCollege.Domain.Entities.Course>>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">My Students</h1>
        <p class="text-muted">Students enrolled in courses you teach</p>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Student Name</th>
                    <th>Student Number</th>
                    <th>Email</th>
                    <th>Courses</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var student in Model)
                    {
                        var courses = studentCourses?.ContainsKey(student.Id) == true 
                            ? studentCourses[student.Id] 
                            : new List<VgcCollege.Domain.Entities.Course>();
                        <tr>
                            <td class="fw-semibold">@student.Name</td>
                            <td>@student.StudentNumber</td>
                            <td>@student.Email</td>
                            <td>
                                @foreach (var course in courses.Take(2))
                                {
                                    <span class="badge bg-secondary me-1">@course.Name</span>
                                }
                                @if (courses.Count > 2)
                                {
                                    <span class="badge bg-info">+@(courses.Count - 2) more</span>
                                }
                            </td>
                            <td>
                                <a asp-action="StudentDetails" asp-route-id="@student.Id" 
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View Details
                                </a>
                                <a asp-action="EnterGrades" asp-route-courseId="@courses.FirstOrDefault()?.Id" 
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i> Enter Grades
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-3">
                            <i class="bi bi-info-circle me-1"></i> No students enrolled in your courses yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>